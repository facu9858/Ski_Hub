--  HELPERS
-- ══════════════════════════════════════════════════════════════
local function getChar() return LocalPlayer.Character end
local function getHRP()
    local c = getChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c = getChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end

local function getNearestPlayer()
    local nearest, dist = nil, math.huge
    local myHRP = getHRP()
    if not myHRP then return nil end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local d = (hrp.Position - myHRP.Position).Magnitude
                if d < dist then dist = d; nearest = p end
            end
        end
    end
    return nearest
end

local function pressKey(keyStr, holdTime)
    pcall(function()
        local hrp = getHRP(); if not hrp then return end
        VIM:SendKeyEvent(true,  Enum.KeyCode[keyStr], false, hrp)
        task.wait(holdTime or 0.15)
        VIM:SendKeyEvent(false, Enum.KeyCode[keyStr], false, hrp)
    end)
end

-- ══════════════════════════════════════════════════════════════
--  FAST ATTACK
-- ══════════════════════════════════════════════════════════════
local function startFastAttack()
    if S.FastAttackConn then task.cancel(S.FastAttackConn) end
    S.FastAttackConn = task.spawn(function()
        while S.FastAttack do
            task.wait(0.005)
            pcall(function()
                local myHRP = getHRP(); if not myHRP then return end
                local targets = {}
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                        local hum = p.Character:FindFirstChild("Humanoid")
                        if hrp and hum and hum.Health > 0 and (hrp.Position - myHRP.Position).Magnitude <= S.FastRange then
                            table.insert(targets, p.Character)
                        end
                    end
                end
                if #targets > 0 and RegisterHit and RegisterAttack then
                    local allTargets = {}
                    for _, char in pairs(targets) do
                        local head = char:FindFirstChild("Head")
                        if head then table.insert(allTargets, {char, head}) end
                    end
                    RegisterAttack:FireServer(0)
                    if allTargets[1] then RegisterHit:FireServer(allTargets[1][2], allTargets) end
                end
            end)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
--  SILENT AIM + AIM GUN
-- ══════════════════════════════════════════════════════════════
local function installSilentAim()
    if S.SilentInstalled then return end
    S.SilentInstalled = true

    task.spawn(function()
        while true do
            task.wait()
            if S.SilentAim or S.AimGun then
                pcall(function()
                    local t = getNearestPlayer()
                    if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
                        S.SilentTarget = t.Name
                        S.SilentPos    = t.Character.HumanoidRootPart.Position
                    else
                        S.SilentTarget = nil; S.SilentPos = nil
                    end
                end)
            else
                S.SilentTarget = nil; S.SilentPos = nil
            end
        end
    end)

    task.spawn(function()
        local mt = getrawmetatable(game)
        local oldNC = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(...)
            local method = getnamecallmethod()
            local args = {...}
            if (S.SilentAim or S.AimGun) and S.SilentPos
               and tostring(method) == "FireServer"
               and tostring(args[1]) == "RemoteEvent"
               and tostring(args[2]) ~= "true"
               and tostring(args[2]) ~= "false" then
                if type(args[2]) == "vector" then
                    args[2] = S.SilentPos
                    return oldNC(unpack(args))
                elseif typeof(args[2]) == "CFrame" then
                    args[2] = CFrame.new(S.SilentPos)
                    return oldNC(unpack(args))
                elseif S.AimGun and type(args[2]) == "string" and args[2] == "TAP" then
                    return oldNC(args[1], "TAP", S.SilentPos, select(4, ...))
                end
            end
            return oldNC(...)
        end)
    end)
end

