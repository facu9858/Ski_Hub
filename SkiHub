--  SAFE ZONE
-- ══════════════════════════════════════════════════════════════
local function startSafeZone()
    if S.SafeZoneConn then S.SafeZoneConn:Disconnect() end
    S.SafeZoneConn = RunService.Heartbeat:Connect(function()
        if not S.SafeZone then return end
        pcall(function()
            local char = getChar(); if not char then return end
            local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return end
            local pct  = (hum.Health / hum.MaxHealth) * 100
            if pct <= S.SafeThreshold then
                local CommF = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("CommF_")
                if CommF then pcall(function() CommF:InvokeServer("SetSafeZone") end) end
            end
        end)
    end)
end

