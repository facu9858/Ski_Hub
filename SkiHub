--  FRUIT ATTACKS
-- ══════════════════════════════════════════════════════════════
local function startFruitAttack(fruitName, connKey, enabledKey, waitTime)
    if S[connKey] then task.cancel(S[connKey]) end
    S[connKey] = task.spawn(function()
        while S[enabledKey] do
            task.wait(waitTime)
            pcall(function()
                local t = getNearestPlayer()
                if not t or not t.Character or not getChar() then return end
                local myHRP  = getHRP(); if not myHRP then return end
                local thrp   = t.Character:FindFirstChild("HumanoidRootPart"); if not thrp then return end
                local dir    = (thrp.Position - myHRP.Position).Unit
                local char   = getChar()
                local tool   = char:FindFirstChild(fruitName)
                if not tool then
                    for _, v in pairs(char:GetChildren()) do
                        if v:IsA("Tool") and v.Name:lower():find(fruitName:lower()) then
                            tool = v; break
                        end
                    end
                end
                if tool then
                    local lr = tool:FindFirstChild("LeftClickRemote")
                    if lr then lr:FireServer(dir, 1, true) end
                end
            end)
        end
    end)
end

