-- ══════════════════════════════════════════════════════════════
--  FLY
-- ══════════════════════════════════════════════════════════════
local function startFly()
    if S.FlyConn then S.FlyConn:Disconnect() end
    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(1e5,1e5,1e5)
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e5,1e5,1e5); bg.D = 100

    local function attachFly()
        local hrp = getHRP(); if not hrp then return end
        bv.Parent = hrp; bg.Parent = hrp
    end
    attachFly()

    S.FlyConn = RunService.RenderStepped:Connect(function()
        if not S.Fly then return end
        pcall(function()
            local hrp = getHRP(); if not hrp then return end
            local cam  = workspace.CurrentCamera
            local dir  = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.new(0,1,0) end
            if dir.Magnitude > 0 then
                bv.Velocity = dir.Unit * S.FlySpeed
                bg.CFrame   = CFrame.new(hrp.Position, hrp.Position + dir)
            else
                bv.Velocity = Vector3.zero
            end
        end)
    end)
end

local function stopFly()
    if S.FlyConn then S.FlyConn:Disconnect(); S.FlyConn = nil end
    pcall(function()
        local hrp = getHRP()
        if hrp then
            local bvf = hrp:FindFirstChildOfClass("BodyVelocity")
            local bgf = hrp:FindFirstChildOfClass("BodyGyro")
            if bvf then bvf:Destroy() end
            if bgf then bgf:Destroy() end
        end
    end)
end

