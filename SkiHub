local PlayerTab = Window:CreateTab("Player", 4483362458)

local dashBoostActive, dashEnd, dashDir = false, 0, Vector3.zero
local dashInstalled = false

local function installDashBoost()
    if dashInstalled then return end
    dashInstalled = true

    task.spawn(function()
        local mt = getrawmetatable(game)
        local oldNC = mt.__namecall
        setreadonly(mt, false)

        mt.__namecall = newcclosure(function(...)
            if S.DashBoost then
                local method = getnamecallmethod()
                local args = {...}

                if tostring(method) == "FireServer"
                and tostring(args[1]) == "CommE"
                and args[2] == "Dodge"
                and args[3] == nil then

                    local hrp = getHRP()
                    local hum = getHum()

                    if hrp and hum then
                        local d = hum.MoveDirection
                        dashDir = (d.Magnitude > 0.1 and d or hrp.CFrame.LookVector).Unit
                        dashBoostActive = true
                        dashEnd = os.clock() + 0.3
                    end
                end
            end

            return oldNC(...)
        end)
    end)

    RunService.Heartbeat:Connect(function(dt)
        if not S.DashBoost or not dashBoostActive then
            return
        end

        if os.clock() > dashEnd then
            dashBoostActive = false
            return
        end

        pcall(function()
            local hrp = getHRP()
            if not hrp then return end

            hrp.CFrame = hrp.CFrame + dashDir * (200 * (S.DashMult - 1) * dt)
        end)
    end)
end

PlayerTab:CreateToggle({
    Name = "Dash Boost",
    CurrentValue = false,
    Flag = "DashBoost",
    Callback = function(Value)
        S.DashBoost = Value
        installDashBoost()
    end
})

PlayerTab:CreateSlider({
    Name = "Dash Multiplier",
    Range = {1, 10},
    Increment = 0.5,
    Suffix = "x",
    CurrentValue = 2,
    Flag = "DashMult",
    Callback = function(Value)
        S.DashMult = Value
    end
})

S.DashMult = 2
