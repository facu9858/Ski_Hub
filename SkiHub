-- ══════════════════════════════════════════════════════════════
local function clearESP()
    for _, obj in pairs(S.ESPObjs) do pcall(function() obj:Destroy() end) end
    S.ESPObjs = {}
end

local function createESP(p)
    if not p.Character or not p.Character:FindFirstChild("Head") then return end
    local head = p.Character.Head
    local bb = Instance.new("BillboardGui")
    bb.Name = "SacredPvPESP"; bb.Adornee = head
    bb.Size = UDim2.new(0,120,0,36); bb.StudsOffset = Vector3.new(0,2.5,0)
    bb.AlwaysOnTop = true; bb.Parent = head

    local lbl = Instance.new("TextLabel", bb)
    lbl.Size = UDim2.new(1,0,0.6,0); lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 13
    lbl.TextColor3 = Color3.fromRGB(0,190,240); lbl.TextStrokeTransparency = 0.3
    lbl.Text = p.Name

    local distLbl = Instance.new("TextLabel", bb)
    distLbl.Size = UDim2.new(1,0,0.4,0); distLbl.Position = UDim2.new(0,0,0.6,0)
    distLbl.BackgroundTransparency = 1; distLbl.Font = Enum.Font.Gotham
    distLbl.TextSize = 10; distLbl.TextColor3 = Color3.fromRGB(150,160,200)
    distLbl.TextStrokeTransparency = 0.3

    table.insert(S.ESPObjs, bb)

    task.spawn(function()
        while bb and bb.Parent and S.ESP do
            task.wait(0.2)
            pcall(function()
                local myHRP = getHRP()
                local hrp   = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                if myHRP and hrp then
                    local dist = math.floor((hrp.Position - myHRP.Position).Magnitude)
                    distLbl.Text = dist .. "m"
                end
            end)
        end
        pcall(function() bb:Destroy() end)
    end)
end

local function updateESP()
    clearESP()
    if not S.ESP then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then createESP(p) end
    end
end

Players.PlayerAdded:Connect(function(p)
    if S.ESP then
        p.CharacterAdded:Connect(function() task.wait(1); createESP(p) end)
    end
end)

