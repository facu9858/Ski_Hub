local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer

local soruAimEnabled = false
local silentAimEnabled = false
local selectedRange = 300
local targetName = ""
local teamCheck = true

local espEnabled = false
local espObjs = {}

local dashBoostEnabled = false
local dashMult = 2
local dashBoostActive = false
local dashEnd = 0
local dashDir = Vector3.zero
local dashInstalled = false
local silentInstalled = false

-- FUNCIONES BASE
local function getHRP()
    local char = lp.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    local char = lp.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function isEnemy(p)
    if not p or p == lp then return false end
    if not teamCheck then return true end
    if lp.Team and p.Team then
        if p.Team == lp.Team then return false end
    end
    return true
end

local function getTarget()
    local hrp = getHRP()
    if not hrp then return nil end

    if targetName ~= "" then
        local p = Players:FindFirstChild(targetName)
        if p and p.Character and isEnemy(p) then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            local eHRP = p.Character:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and eHRP then return p end
        end
    end

    local closest, closestDist = nil, selectedRange
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character then
            local eHRP = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if eHRP and hum and hum.Health > 0 then
                local d = (eHRP.Position - hrp.Position).Magnitude
                if d < closestDist then
                    closest = p
                    closestDist = d
                end
            end
        end
    end
    return closest
end

-- Obtener color y bando del jugador
local function getTeamInfo(p)
    if p.Team then
        local teamName = p.Team.Name
        if teamName:lower():find("pirat") then
            return "Pirata", Color3.fromRGB(255, 60, 60)
        elseif teamName:lower():find("marin") then
            return "Marino", Color3.fromRGB(0, 190, 240)
        else
            return teamName, p.Team.TeamColor.Color
        end
    end
    return "Sin bando", Color3.fromRGB(200, 200, 200)
end

-- Obtener nivel del jugador
local function getPlayerLevel(p)
    local char = p.Character
    if not char then return "?" end
    -- Blox Fruits guarda el nivel en un valor dentro del personaje o leaderstats
    local leaderstats = p:FindFirstChild("leaderstats")
    if leaderstats then
        local level = leaderstats:FindFirstChild("Level") or leaderstats:FindFirstChild("Lv") or leaderstats:FindFirstChild("level")
        if level then return tostring(level.Value) end
    end
    -- Alternativa: buscar en el personaje
    local levelVal = char:FindFirstChild("Level") or char:FindFirstChild("Lv")
    if levelVal then return tostring(levelVal.Value) end
    return "?"
end

-- SORU AIM
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, key)
    if soruAimEnabled and self == lp:GetMouse() then
        local enemy = getTarget()
        if enemy and enemy.Character then
            local eHRP = enemy.Character:FindFirstChild("HumanoidRootPart")
            if eHRP then
                if key == "Hit" then
                    return CFrame.new(eHRP.Position)
                elseif key == "Target" then
                    return eHRP
                end
            end
        end
    end
    return oldIndex(self, key)
end)

setreadonly(mt, true)

-- SILENT AIM
local silentPos = nil

local function installSilentAim()
    if silentInstalled then return end
    silentInstalled = true

    task.spawn(function()
        while true do
            task.wait()
            if silentAimEnabled then
                pcall(function()
                    local t = getTarget()
                    if t and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
                        silentPos = t.Character.HumanoidRootPart.Position
                    else
                        silentPos = nil
                    end
                end)
            else
                silentPos = nil
            end
        end
    end)

    task.spawn(function()
        local mt2 = getrawmetatable(game)
        local oldNC = mt2.__namecall
        setreadonly(mt2, false)

        mt2.__namecall = newcclosure(function(...)
            local method = getnamecallmethod()
            local args = {...}

            if silentAimEnabled
            and silentPos
            and tostring(method) == "FireServer"
            and tostring(args[1]) == "RemoteEvent" then
                if typeof(args[2]) == "Vector3" then
                    args[2] = silentPos
                    return oldNC(unpack(args))
                elseif typeof(args[2]) == "CFrame" then
                    args[2] = CFrame.new(silentPos)
                    return oldNC(unpack(args))
                end
            end

            return oldNC(...)
        end)

        setreadonly(mt2, true)
    end)
end

-- DASH BOOST
local function installDashBoost()
    if dashInstalled then return end
    dashInstalled = true

    task.spawn(function()
        local mt3 = getrawmetatable(game)
        local oldNC2 = mt3.__namecall
        setreadonly(mt3, false)

        mt3.__namecall = newcclosure(function(...)
            if dashBoostEnabled then
                local method = getnamecallmethod()
                local args = {...}
                if tostring(method) == "FireServer"
                and tostring(args[1]) == "CommE"
                and args[2] == "Dodge"
                and args[3] == nil then
                    local hrp = getHRP()
                    local hum = getHum()
                    if hrp and hum then
                        local d = hum.MoveDirection
                        dashDir = (d.Magnitude > 0.1 and d or hrp.CFrame.LookVector).Unit
                        dashBoostActive = true
                        dashEnd = os.clock() + 0.3
                    end
                end
            end
            return oldNC2(...)
        end)

        setreadonly(mt3, true)
    end)

    RunService.Heartbeat:Connect(function(dt)
        if not dashBoostEnabled or not dashBoostActive then return end
        if os.clock() > dashEnd then dashBoostActive = false return end
        pcall(function()
            local hrp = getHRP()
            if hrp then
                hrp.CFrame = hrp.CFrame + dashDir * (200 * (dashMult - 1) * dt)
            end
        end)
    end)
end

-- ESP MEJORADO
local function clearESP()
    for _, obj in pairs(espObjs) do
        pcall(function() obj:Destroy() end)
    end
    espObjs = {}
end

local function createESP(p)
    if not p.Character or not p.Character:FindFirstChild("Head") then return end
    local head = p.Character.Head

    local bb = Instance.new("BillboardGui")
    bb.Name = "MiScriptESP"
    bb.Adornee = head
    bb.Size = UDim2.new(0, 160, 0, 90)
    bb.StudsOffset = Vector3.new(0, 3, 0)
    bb.AlwaysOnTop = true
    bb.Parent = head

    local frame = Instance.new("Frame", bb)
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1

    -- Nombre
    local nameLbl = Instance.new("TextLabel", frame)
    nameLbl.Size = UDim2.new(1, 0, 0.25, 0)
    nameLbl.Position = UDim2.new(0, 0, 0, 0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextSize = 13
    nameLbl.TextStrokeTransparency = 0.3
    nameLbl.Text = p.Name

    -- Bando
    local teamLbl = Instance.new("TextLabel", frame)
    teamLbl.Size = UDim2.new(1, 0, 0.25, 0)
    teamLbl.Position = UDim2.new(0, 0, 0.25, 0)
    teamLbl.BackgroundTransparency = 1
    teamLbl.Font = Enum.Font.GothamBold
    teamLbl.TextSize = 12
    teamLbl.TextStrokeTransparency = 0.3

    -- Vida
    local hpLbl = Instance.new("TextLabel", frame)
    hpLbl.Size = UDim2.new(1, 0, 0.25, 0)
    hpLbl.Position = UDim2.new(0, 0, 0.5, 0)
    hpLbl.BackgroundTransparency = 1
    hpLbl.Font = Enum.Font.Gotham
    hpLbl.TextSize = 11
    hpLbl.TextColor3 = Color3.fromRGB(100, 255, 100)
    hpLbl.TextStrokeTransparency = 0.3

    -- Distancia y nivel
    local infoLbl = Instance.new("TextLabel", frame)
    infoLbl.Size = UDim2.new(1, 0, 0.25, 0)
    infoLbl.Position = UDim2.new(0, 0, 0.75, 0)
    infoLbl.BackgroundTransparency = 1
    infoLbl.Font = Enum.Font.Gotham
    infoLbl.TextSize = 11
    infoLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    infoLbl.TextStrokeTransparency = 0.3

    -- Aplicar color de bando
    local bandoName, bandoColor = getTeamInfo(p)
    nameLbl.TextColor3 = bandoColor
    teamLbl.TextColor3 = bandoColor
    teamLbl.Text = "【" .. bandoName .. "】"

    table.insert(espObjs, bb)

    task.spawn(function()
        while bb and bb.Parent and espEnabled do
            task.wait(0.2)
            pcall(function()
                local myHRP = getHRP()
                local eHRP = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                local hum = p.Character and p.Character:FindFirstChildOfClass("Humanoid")

                if myHRP and eHRP then
                    local dist = math.floor((eHRP.Position - myHRP.Position).Magnitude)
                    local level = getPlayerLevel(p)
                    infoLbl.Text = "Lv." .. level .. "  |  " .. dist .. "m"
                end

                if hum then
                    local hp = math.floor(hum.Health)
                    local maxHp = math.floor(hum.MaxHealth)
                    hpLbl.Text = "❤️ " .. hp .. " / " .. maxHp

                    -- Color de vida: verde → amarillo → rojo
                    local ratio = hum.Health / hum.MaxHealth
                    if ratio > 0.6 then
                        hpLbl.TextColor3 = Color3.fromRGB(100, 255, 100)
                    elseif ratio > 0.3 then
                        hpLbl.TextColor3 = Color3.fromRGB(255, 200, 0)
                    else
                        hpLbl.TextColor3 = Color3.fromRGB(255, 60, 60)
                    end
                end

                -- Actualizar bando por si cambia
                local newBando, newColor = getTeamInfo(p)
                nameLbl.TextColor3 = newColor
                teamLbl.TextColor3 = newColor
                teamLbl.Text = "【" .. newBando .. "】"
            end)
        end
        pcall(function() bb:Destroy() end)
    end)
end

local function updateESP()
    clearESP()
    if not espEnabled then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp then createESP(p) end
    end
end

Players.PlayerAdded:Connect(function(p)
    if espEnabled then
        p.CharacterAdded:Connect(function()
            task.wait(1)
            createESP(p)
        end)
    end
end)

