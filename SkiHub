local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local lp = Players.LocalPlayer
local camera = workspace.CurrentCamera

local silentAimEnabled = false
local cameraLockEnabled = false
local selectedRange = 300
local targetName = ""
local teamCheck = true
local lockKey = Enum.KeyCode.E

local espEnabled = false
local espObjs = {}

local dashBoostEnabled = false
local dashMult = 2
local dashBoostActive = false
local dashEnd = 0
local dashDir = Vector3.zero
local dashInstalled = false

-- FUNCIONES BASE
local function getHRP()
    local char = lp.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    local char = lp.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function isEnemy(p)
    if not p or p == lp then return false end
    if not teamCheck then return true end
    if lp.Team and p.Team then
        if p.Team == lp.Team then return false end
    end
    return true
end

local function getTarget()
    local hrp = getHRP()
    if not hrp then return nil end

    if targetName ~= "" then
        local p = Players:FindFirstChild(targetName)
        if p and p.Character and isEnemy(p) then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            local eHRP = p.Character:FindFirstChild("HumanoidRootPart")
            if hum and hum.Health > 0 and eHRP then return p end
        end
    end

    local closest, closestDist = nil, selectedRange
    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p) and p.Character then
            local eHRP = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if eHRP and hum and hum.Health > 0 then
                local d = (eHRP.Position - hrp.Position).Magnitude
                if d < closestDist then
                    closest = p
                    closestDist = d
                end
            end
        end
    end
    return closest
end

-- SILENT AIM
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, key)
    if silentAimEnabled and self == lp:GetMouse() then
        local enemy = getTarget()
        if enemy and enemy.Character then
            local eHRP = enemy.Character:FindFirstChild("HumanoidRootPart")
            if eHRP then
                if key == "Hit" then
                    return CFrame.new(eHRP.Position)
                elseif key == "Target" then
                    return eHRP
                end
            end
        end
    end
    return oldIndex(self, key)
end)

setreadonly(mt, true)

-- CAMERA LOCK (sigue al enemigo con la cámara, puedes moverla libremente cuando está OFF)
RunService.RenderStepped:Connect(function()
    if not cameraLockEnabled then return end
    local enemy = getTarget()
    if not enemy or not enemy.Character then return end
    local eHRP = enemy.Character:FindFirstChild("HumanoidRootPart")
    if not eHRP then return end
    -- Solo apunta la cámara al enemigo, sin bloquear movimiento
    local camPos = camera.CFrame.Position
    camera.CFrame = CFrame.lookAt(camPos, eHRP.Position)
end)

-- TECLA para activar/desactivar Camera Lock
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == lockKey then
        cameraLockEnabled = not cameraLockEnabled
        Rayfield:Notify({
            Title = cameraLockEnabled and "🎥 Camera Lock ON" or "🎥 Camera Lock OFF",
            Content = cameraLockEnabled and "Cámara siguiendo al enemigo." or "Cámara libre.",
            Duration = 2,
            Image = 4483362458,
        })
    end
end)

-- DASH BOOST
local function installDashBoost()
    if dashInstalled then return end
    dashInstalled = true

    task.spawn(function()
        local mt2 = getrawmetatable(game)
        local oldNC = mt2.__namecall
        setreadonly(mt2, false)

        mt2.__namecall = newcclosure(function(...)
            if dashBoostEnabled then
                local method = getnamecallmethod()
                local args = {...}
                if tostring(method) == "FireServer"
                and tostring(args[1]) == "CommE"
                and args[2] == "Dodge"
                and args[3] == nil then
                    local hrp = getHRP()
                    local hum = getHum()
                    if hrp and hum then
                        local d = hum.MoveDirection
                        dashDir = (d.Magnitude > 0.1 and d or hrp.CFrame.LookVector).Unit
                        dashBoostActive = true
                        dashEnd = os.clock() + 0.3
                    end
                end
            end
            return oldNC(...)
        end)

        setreadonly(mt2, true)
    end)

    RunService.Heartbeat:Connect(function(dt)
        if not dashBoostEnabled or not dashBoostActive then return end
        if os.clock() > dashEnd then dashBoostActive = false return end
        pcall(function()
            local hrp = getHRP()
            if hrp then
                hrp.CFrame = hrp.CFrame + dashDir * (200 * (dashMult - 1) * dt)
            end
        end)
    end)
end

-- ESP
local function clearESP()
    for _, obj in pairs(espObjs) do
        pcall(function() obj:Destroy() end)
    end
    espObjs = {}
end

local function createESP(p)
    if not p.Character or not p.Character:FindFirstChild("Head") then return end
    local head = p.Character.Head

    local bb = Instance.new("BillboardGui")
    bb.Name = "SilentAimESP"
    bb.Adornee = head
    bb.Size = UDim2.new(0, 120, 0, 36)
    bb.StudsOffset = Vector3.new(0, 2.5, 0)
    bb.AlwaysOnTop = true
    bb.Parent = head

    local lbl = Instance.new("TextLabel", bb)
    lbl.Size = UDim2.new(1, 0, 0.6, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextColor3 = Color3.fromRGB(0, 190, 240)
    lbl.TextStrokeTransparency = 0.3
    lbl.Text = p.Name

    local distLbl = Instance.new("TextLabel", bb)
    distLbl.Size = UDim2.new(1, 0, 0.4, 0)
    distLbl.Position = UDim2.new(0, 0, 0.6, 0)
    distLbl.BackgroundTransparency = 1
    distLbl.Font = Enum.Font.Gotham
    distLbl.TextSize = 10
    distLbl.TextColor3 = Color3.fromRGB(150, 160, 200)
    distLbl.TextStrokeTransparency = 0.3

    table.insert(espObjs, bb)

    task.spawn(function()
        while bb and bb.Parent and espEnabled do
            task.wait(0.2)
            pcall(function()
                local myHRP = getHRP()
                local eHRP = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                if myHRP and eHRP then
                    local dist = math.floor((eHRP.Position - myHRP.Position).Magnitude)
                    distLbl.Text = dist .. "m"
                end
            end)
        end
        pcall(function() bb:Destroy() end)
    end)
end

local function updateESP()
    clearESP()
    if not espEnabled then return end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp then createESP(p) end
    end
end

Players.PlayerAdded:Connect(function(p)
    if espEnabled then
        p.CharacterAdded:Connect(function()
            task.wait(1)
            createESP(p)
        end)
    end
end)

