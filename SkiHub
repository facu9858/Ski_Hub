-- FUNCS
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

-- DASH BOOST
local dashBoostActive, dashEnd, dashDir = false, 0, Vector3.zero
local dashInstalled = false

local function installDashBoost()
    if dashInstalled then return end
    dashInstalled = true

    task.spawn(function()
        local mt = getrawmetatable(game)
        local oldNC = mt.__namecall

        setreadonly(mt, false)

        mt.__namecall = newcclosure(function(...)
            if S.DashBoost then
                local method = getnamecallmethod()
                local args = {...}

                if tostring(method) == "FireServer"
                and tostring(args[1]) == "CommE"
                and args[2] == "Dodge"
                and args[3] == nil then

                    local hrp = getHRP()
                    local hum = getHum()

                    if hrp and hum then
                        local d = hum.MoveDirection
                        dashDir = (d.Magnitude > 0.1 and d or hrp.CFrame.LookVector).Unit
                        dashBoostActive = true
                        dashEnd = os.clock() + 0.3
                    end
                end
            end

            return oldNC(...)
        end)

        setreadonly(mt, true)
    end)

    RunService.Heartbeat:Connect(function(dt)
        if not S.DashBoost or not dashBoostActive then
            return
        end

        if os.clock() > dashEnd then
            dashBoostActive = false
            return
        end

        pcall(function()
            local hrp = getHRP()
            if not hrp then return end

            hrp.CFrame = hrp.CFrame + dashDir * (200 * (S.DashMult - 1) * dt)
        end)
    end)
end

-- ESP
local function clearESP()
    for _, obj in pairs(S.ESPObjs) do
        pcall(function()
            obj:Destroy()
        end)
    end

    S.ESPObjs = {}
end

local function createESP(p)
    if not p.Character or not p.Character:FindFirstChild("Head") then
        return
    end

    local head = p.Character.Head

    local bb = Instance.new("BillboardGui")
    bb.Name = "SacredPvPESP"
    bb.Adornee = head
    bb.Size = UDim2.new(0,120,0,36)
    bb.StudsOffset = Vector3.new(0,2.5,0)
    bb.AlwaysOnTop = true
    bb.Parent = head

    local lbl = Instance.new("TextLabel", bb)
    lbl.Size = UDim2.new(1,0,0.6,0)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 13
    lbl.TextColor3 = Color3.fromRGB(0,190,240)
    lbl.TextStrokeTransparency = 0.3
    lbl.Text = p.Name

    local distLbl = Instance.new("TextLabel", bb)
    distLbl.Size = UDim2.new(1,0,0.4,0)
    distLbl.Position = UDim2.new(0,0,0.6,0)
    distLbl.BackgroundTransparency = 1
    distLbl.Font = Enum.Font.Gotham
    distLbl.TextSize = 10
    distLbl.TextColor3 = Color3.fromRGB(150,160,200)
    distLbl.TextStrokeTransparency = 0.3

    table.insert(S.ESPObjs, bb)

    task.spawn(function()
        while bb and bb.Parent and S.ESP do
            task.wait(0.2)

            pcall(function()
                local myHRP = getHRP()
                local hrp = p.Character and p.Character:FindFirstChild("HumanoidRootPart")

                if myHRP and hrp then
                    local dist = math.floor((hrp.Position - myHRP.Position).Magnitude)
                    distLbl.Text = dist .. "m"
                end
            end)
        end

        pcall(function()
            bb:Destroy()
        end)
    end)
end

local function updateESP()
    clearESP()

    if not S.ESP then
        return
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            createESP(p)
        end
    end
end

Players.PlayerAdded:Connect(function(p)
    if S.ESP then
        p.CharacterAdded:Connect(function()
            task.wait(1)
            createESP(p)
        end)
    end
end)

-- SILENT AIM FIXED
local function isEnemy(p)
    if not p or p == LocalPlayer then
        return false
    end

    if LocalPlayer.Team ~= nil and p.Team ~= nil then
        if p.Team == LocalPlayer.Team then
            return false
        end
    end

    return true
end

local function getNearestPlayer()
    local closest = nil
    local shortestDistance = math.huge

    for _, p in ipairs(Players:GetPlayers()) do
        if isEnemy(p)
        and p.Character
        and p.Character:FindFirstChild("HumanoidRootPart") then

            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            local myHRP = getHRP()

            if hum and hum.Health > 0 and myHRP then
                local dist = (
                    p.Character.HumanoidRootPart.Position
                    - myHRP.Position
                ).Magnitude

                if dist < shortestDistance then
                    shortestDistance = dist
                    closest = p
                end
            end
        end
    end

    return closest
end

local function installSilentAim()
    if S.SilentInstalled then return end
    S.SilentInstalled = true

    task.spawn(function()
        while true do
            task.wait()

            if S.SilentAim or S.AimGun then
                pcall(function()
                    local t = getNearestPlayer()

                    if t
                    and t.Character
                    and t.Character:FindFirstChild("HumanoidRootPart") then

                        S.SilentTarget = t.Name
                        S.SilentPos = t.Character.HumanoidRootPart.Position
                    else
                        S.SilentTarget = nil
                        S.SilentPos = nil
                    end
                end)
            else
                S.SilentTarget = nil
                S.SilentPos = nil
            end
        end
    end)

    task.spawn(function()
        local mt = getrawmetatable(game)
        local oldNC = mt.__namecall

        setreadonly(mt, false)

        mt.__namecall = newcclosure(function(...)
            local method = getnamecallmethod()
            local args = {...}

            if (S.SilentAim or S.AimGun)
            and S.SilentPos
            and tostring(method) == "FireServer"
            and tostring(args[1]) == "RemoteEvent"
            and tostring(args[2]) ~= "true"
            and tostring(args[2]) ~= "false" then

                if typeof(args[2]) == "Vector3" then
                    args[2] = S.SilentPos
                    return oldNC(unpack(args))

                elseif typeof(args[2]) == "CFrame" then
                    args[2] = CFrame.new(S.SilentPos)
                    return oldNC(unpack(args))

                elseif S.AimGun
                and type(args[2]) == "string"
                and args[2] == "TAP" then

                    return oldNC(args[1], "TAP", S.SilentPos, select(4, ...))
                end
            end

            return oldNC(...)
        end)

        setreadonly(mt, true)
    end)
end

